    "Add a remote MCP server to discover and use its tools": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge einen Remote-MCP-Server hinzu, um seine Tools zu entdecken und zu nutzen"
