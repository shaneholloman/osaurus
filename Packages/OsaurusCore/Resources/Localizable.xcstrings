    "Adjust how sensitive voice detection is": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Empfindlichkeit der Spracherkennung anpassen"
          }
        }
      }
    },
    "Affects pause detection, wake word detection, and voice activity thresholds": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beeinflusst Pausenerkennung, Aktivierungswort-Erkennung und Sprachaktivitätsschwellen"
          }
        }
      }
    },
    "Agent can create its own tools as plugins": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Agent kann eigene Tools als Plugins erstellen"
