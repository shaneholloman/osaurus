    "Allow": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlauben"
          }
        }
      }
    },
    "Allow agent to run arbitrary commands in the sandbox": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Agent darf beliebige Befehle in der Sandbox ausführen"
          }
        }
      }
    },
    "Allows capturing system audio for transcription. Screen content is not recorded.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt das Aufnehmen von System-Audio für Transkription. Bildschirminhalte werden nicht aufgezeichnet."
          }
        }
      }
    },
    "Allows plugins to access and search contacts.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, auf Kontakte zuzugreifen und sie zu durchsuchen."
          }
        }
      }
    },
    "Allows plugins to access protected files like the Messages database and other app data.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, auf geschützte Dateien wie die Nachrichten-Datenbank und andere App-Daten zuzugreifen."
          }
        }
      }
    },
    "Allows plugins to access your calendar to read and create events directly.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, direkt auf deinen Kalender zuzugreifen, um Termine zu lesen und zu erstellen."
          }
        }
      }
    },
    "Allows plugins to access your current location.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, auf deinen aktuellen Standort zuzugreifen."
          }
        }
      }
    },
    "Allows plugins to access your reminders to read and create tasks.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, auf deine Erinnerungen zuzugreifen, um Aufgaben zu lesen und zu erstellen."
          }
        }
      }
    },
    "Allows plugins to control Maps app via AppleScript.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, die Karten-App via AppleScript zu steuern."
          }
        }
      }
    },
    "Allows plugins to control other applications using AppleScript and Apple Events.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, andere Apps via AppleScript und Apple Events zu steuern."
          }
        }
      }
    },
    "Allows plugins to interact with UI elements, simulate input, and control the computer.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, mit UI-Elementen zu interagieren, Eingaben zu simulieren und den Computer zu steuern."
          }
        }
      }
    },
    "Allows plugins to read and create events in Calendar.app via AppleScript.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, Termine in Kalender.app via AppleScript zu lesen und zu erstellen."
          }
        }
      }
    },
    "Allows plugins to read and create notes in the Notes app via AppleScript.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, Notizen in der Notizen-App via AppleScript zu lesen und zu erstellen."
          }
        }
      }
    },
    "Allows plugins to read and send emails in Mail.app via AppleScript.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, Mails in Mail.app via AppleScript zu lesen und zu senden."
          }
        }
      }
    },
    "Allows voice transcription using the microphone for speech-to-text.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Sprach-Transkription über das Mikrofon für Speech-to-Text."
          }
        }
      }
    },
